---
import { useTranslations, localizedPath, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description?: string;
}
const { locale, title, description } = Astro.props;
const t = useTranslations(locale);
const otherLocale: Locale = locale === 'zh' ? 'en' : 'zh';
const htmlLang = locale === 'zh' ? 'zh-Hant' : 'en';
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/images/site/logo.svg" />
    <!-- Nunito Sans is the old site's brand typeface. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:ital,opsz,wght@0,6..12,200..1000;1,6..12,200..1000&display=swap" rel="stylesheet" />
    <!-- hreflang tells Google the zh/en pages are the same content in two
         languages. Important for the SEO migration from the old site. -->
    <link rel="alternate" hreflang="zh-Hant" href={new URL(localizedPath('zh', Astro.url.pathname.replace(/^\/en/, '') || '/'), Astro.site)} />
    <link rel="alternate" hreflang="en" href={new URL(localizedPath('en', Astro.url.pathname.replace(/^\/en/, '') || '/'), Astro.site)} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={localizedPath(locale, '/')}>
        <img src="/images/site/logo.svg" alt="JD Niseko" />
        JD Snowdrift &amp; Summer Sports
      </a>
      <nav>
        <a href={localizedPath(locale, '/')}>{t('nav.home')}</a>
        <a href={localizedPath(locale, '/lessons')}>{t('nav.lessons')}</a>
        <a href={localizedPath(locale, '/about')}>{t('nav.about')}</a>
        <a href={localizedPath(locale, '/contact')}>{t('nav.contact')}</a>
      </nav>
      <!-- Language switch keeps the user on the same page in the other locale -->
      <a class="lang-switch" href={localizedPath(otherLocale, Astro.url.pathname.replace(/^\/en/, '') || '/')}>
        {t('lang.switch')}
      </a>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>{t('footer.certified')}</p>
      <p>{t('footer.company')}</p>
      <p>{t('footer.address')}</p>
      <p>{t('footer.license')}</p>
      <p>&copy; {new Date().getFullYear()} JD G.K. All rights reserved.</p>
    </footer>

    <style>
      /* Palette pulled directly from jdnisekosss.com's computed styles:
         dark navy body (#092234), darker navy header (#001D2E), and a
         gold accent (#C59D5F) used everywhere for headings/buttons/badges. */
      :root {
        --bg: #092234;
        --bg-header: #001d2e;
        --bg-card: #15293a;
        --bg-panel: #324757;
        --ink: #ffffff;
        --ink-on-panel: #ffffff;
        --accent: #c59d5f;
        --muted: #8c9ca8;
        --line: rgba(255, 255, 255, 0.12);
        font-family: "Nunito Sans", "Noto Sans TC", "Microsoft JhengHei", sans-serif;
      }
      * { box-sizing: border-box; }
      body { margin: 0; color: var(--ink); background: var(--bg); line-height: 1.6; }
      .site-header {
        display: flex; align-items: center; gap: 1.5rem;
        padding: 1rem 1.5rem; border-bottom: 1px solid var(--line);
        position: sticky; top: 0; background: var(--bg-header); z-index: 10;
      }
      .brand { display: flex; align-items: center; gap: 0.6rem; font-weight: 700; font-size: 1.1rem; text-decoration: none; color: var(--ink); }
      .brand img { height: 32px; width: 32px; }
      nav { display: flex; gap: 1.25rem; margin-right: auto; }
      nav a, .lang-switch { text-decoration: none; color: var(--muted); }
      nav a:hover { color: var(--accent); }
      .lang-switch { font-weight: 600; color: var(--accent); }
      main { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; }
      h1, h2, h3 { color: var(--accent); }
      a { color: var(--accent); }
      .site-footer {
        border-top: 1px solid var(--line); padding: 2rem 1.5rem;
        background: var(--bg-header);
        color: var(--muted); font-size: 0.85rem; text-align: center;
      }
    </style>
  </body>
</html>
