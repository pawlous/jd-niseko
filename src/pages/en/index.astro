---
import Base from '../../layouts/Base.astro';
import TeamGrid from '../../components/TeamGrid.astro';
import PartnersGrid from '../../components/PartnersGrid.astro';
import { useTranslations } from '../../i18n/utils';
import { liftStatusLinks } from '../../data/partners';

const locale = 'en' as const;
const t = useTranslations(locale);
---
<Base locale={locale} title="JD Niseko Ski & Snowboard School" description={t('hero.subtitle')}>
  <section class="hero">
    <h1>{t('hero.tagline')}</h1>
    <p class="subtitle">{t('hero.subtitle')}</p>
    <p class="intro">{t('hero.intro')}</p>
    <a class="cta" href="/en/lessons">{t('nav.lessons')}</a>
  </section>

  <section class="badges">
    <div class="badge"><h3>{t('hero.badge1.title')}</h3><p>{t('hero.badge1.desc')}</p></div>
    <div class="badge"><h3>{t('hero.badge2.title')}</h3><p>{t('hero.badge2.desc')}</p></div>
    <div class="badge"><h3>{t('hero.badge3.title')}</h3><p>{t('hero.badge3.desc')}</p></div>
    <div class="badge"><h3>{t('hero.badge4.title')}</h3><p>{t('hero.badge4.desc')}</p></div>
  </section>

  <section class="about">
    <h2>{t('about.heading')}</h2>
    <p>{t('about.body')}</p>
  </section>

  <section class="process">
    <h2>{t('process.heading')}</h2>
    <ol>
      <li>{t('process.step1')}</li>
      <li>{t('process.step2')}</li>
      <li>{t('process.step3')}</li>
      <li>{t('process.step4')}</li>
      <li>{t('process.step5')}</li>
    </ol>
  </section>

  <section class="team">
    <h2>{t('team.heading')}</h2>
    <p class="section-intro">{t('team.intro')}</p>
    <TeamGrid locale={locale} />
  </section>

  <section class="partners">
    <h2>{t('partners.heading')}</h2>
    <p class="section-intro">{t('partners.intro')}</p>
    <PartnersGrid />
  </section>

  <section class="lift-status">
    <h2>{t('lift.heading')}</h2>
    <ul>
      {liftStatusLinks.map((l) => (
        <li><a href={l.url} target="_blank" rel="noopener noreferrer">{l.name}</a></li>
      ))}
    </ul>
  </section>

  <style>
    .hero { text-align: center; padding: 3rem 0; }
    .hero h1 { font-size: 2rem; margin-bottom: 0.5rem; }
    .hero .subtitle { color: var(--muted); font-size: 1.1rem; }
    .hero .intro { max-width: 720px; margin: 1rem auto 0; color: var(--muted); }
    .cta { display: inline-block; margin-top: 1.5rem; background: var(--accent); color: white; padding: 0.8rem 1.6rem; border-radius: 8px; text-decoration: none; font-weight: 600; }

    .badges { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin: 2rem 0; }
    .badge { border: 1px solid var(--line); border-radius: 10px; padding: 1.25rem; text-align: center; }
    .badge h3 { margin: 0 0 0.5rem; font-size: 1rem; }
    .badge p { margin: 0; color: var(--muted); font-size: 0.85rem; }

    section { margin: 3rem 0; }
    section h2 { margin-bottom: 0.5rem; }
    .section-intro { color: var(--muted); margin-top: 0; }

    .process ol { padding-left: 1.25rem; }
    .lift-status ul { list-style: none; padding: 0; display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .lift-status a { color: var(--accent); text-decoration: none; font-weight: 600; }
  </style>
</Base>
