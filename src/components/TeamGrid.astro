---
import type { Locale } from '../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const instructors = (await getCollection('instructors', ({ id }) => id.startsWith(`${locale}/`)))
  .sort((a, b) => a.data.order - b.data.order);
---

<div class="team-grid">
  {instructors.map((person) => (
    <article class="person">
      {person.data.photo && <img src={person.data.photo} alt={person.data.name} loading="lazy" />}
      <h3>{person.data.name}</h3>
      <p class="role">{person.data.role}</p>
      {person.data.certificates.length > 0 && (
        <ul class="certs">
          {person.data.certificates.map((cert) => <li>{cert}</li>)}
        </ul>
      )}
    </article>
  ))}
</div>

<style>
  .team-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem; }
  .person { border: 1px solid var(--line); border-radius: 12px; overflow: hidden; text-align: center; padding-bottom: 1rem; }
  .person img { width: 100%; height: 220px; object-fit: cover; }
  .person h3 { margin: 0.75rem 0 0.1rem; }
  .role { color: var(--muted); font-size: 0.9rem; margin: 0 0 0.5rem; }
  .certs { list-style: none; display: flex; flex-wrap: wrap; gap: 0.3rem; justify-content: center; padding: 0 1rem; margin: 0; }
  .certs li { background: var(--line); color: var(--ink); font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 999px; }
</style>
